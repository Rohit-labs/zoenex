{
  "$schema": "three-layer design tokens: primitive -> semantic -> component",
  "meta": {
    "brand": "Zoenex Studios",
    "version": "1.0.0",
    "source": "Extracted from app/globals.css, app/layout.tsx, lib/gsap.ts, lib/useViewAnimations.ts, lib/magnetic.ts, components/HeroArt.tsx",
    "contexts": ["light (default)", "on-night (dark bands)"]
  },
  "primitive": {
    "color": {
      "porcelain": { "value": "#F3F0EB", "description": "Page background (1st color)" },
      "bone": { "value": "#E7E4DB", "description": "Card surface (2nd color)" },
      "paper": { "value": "#E7E4DB", "description": "Light text on dark — same as bone" },
      "ink": { "value": "#252323", "description": "Body text (4th color)" },
      "night": { "value": "#181715", "description": "Headings + dark band background (5th color)" },
      "cobalt": { "value": "#243EE8", "description": "The brand accent — 3rd color, used for highlights + hover" },
      "cobalt-soft": { "value": "#E7E4DB", "description": "On-cobalt text — uses bone for contrast" },
      "green": { "value": "#5DE0A0", "description": "Live/availability pulse" },
      "red-border": { "value": "#DD3333", "description": "Invalid field border" },
      "red-text": { "value": "#CC2222", "description": "Inline error copy" },
      "alpha": {
        "ink-62": { "value": "rgba(37,35,35,0.62)", "description": "Secondary text on light" },
        "ink-40": { "value": "rgba(37,35,35,0.40)", "description": "Tertiary text on light" },
        "ink-13": { "value": "rgba(37,35,35,0.13)", "description": "Hairline borders on light" },
        "paper-55": { "value": "rgba(24,23,21,0.55)", "description": "Secondary text on night" },
        "paper-16": { "value": "rgba(24,23,21,0.16)", "description": "Hairline borders on night" },
        "cobalt-15": { "value": "rgba(36,62,232,0.15)", "description": "Focus ring" },
        "cobalt-12": { "value": "rgba(36,62,232,0.12)", "description": "Timeline node halo" }
      },
      "webgl": {
        "hero-wireframe": { "value": "0x243ee8", "description": "Three.js hero sphere wireframe" },
        "hero-sky": { "value": "0x243ee8", "description": "Three.js secondary light" },
        "hero-particles": { "value": "0x252323", "description": "Three.js particle field" }
      }
    },
    "typography": {
      "family": {
        "display": { "value": "'Cabinet Grotesk','Arial Black',sans-serif", "loading": "Fontshare @500,700,800" },
        "body": { "value": "'Satoshi','Helvetica Neue',sans-serif", "loading": "Fontshare @400,500,700" },
        "mono": { "value": "'Space Mono',monospace", "loading": "Google Fonts @400,700" }
      },
      "weight": { "regular": 400, "medium": 500, "bold": 700, "heavy": 800 },
      "size": {
        "mega": { "value": "clamp(52px,9.6vw,150px)", "usage": "Hero headline, uppercase" },
        "xl": { "value": "clamp(38px,6vw,88px)", "usage": "Section headline, uppercase" },
        "lg": { "value": "clamp(26px,3.6vw,48px)", "usage": "Sub-section headline" },
        "md": { "value": "clamp(24px,3vw,40px)", "usage": "Card / step headline, uppercase" },
        "lede": { "value": "clamp(17px,1.45vw,20px)", "usage": "Intro paragraph, max-width 52ch" },
        "body": { "value": "17px", "usage": "Base body copy" },
        "small": { "value": "15px", "usage": "Secondary copy, nav links" },
        "caption": { "value": "13px", "usage": "Fine print, footer bottom" },
        "mono-lg": { "value": "12px", "usage": "Eyebrows, service codes" },
        "mono-md": { "value": "11.5px", "usage": "Mono tags, filter buttons" },
        "mono-sm": { "value": "10.5px", "usage": "Card categories, art labels" }
      },
      "leading": { "display": 0.98, "body": 1.62 },
      "tracking": {
        "display": "-0.015em",
        "mega": "-0.02em to -0.03em (ghost type)",
        "mono-wide": "0.12em",
        "mono-wider": "0.16em"
      },
      "case": "Display headings and all mono labels are uppercase; body copy is sentence case"
    },
    "space": {
      "gutter": { "value": "clamp(20px,4.5vw,64px)", "usage": "Page horizontal gutter (--gut)" },
      "section": { "value": "clamp(90px,12vw,170px)", "usage": "Vertical section rhythm (--pad)" },
      "head-gap": { "value": "clamp(52px,6vw,90px)", "usage": "Section head to content" },
      "container": { "value": "1440px", "usage": ".wrap max-width" },
      "nav-height": { "value": "78px" },
      "grid-gap-cards": { "value": "clamp(16px,1.8vw,24px) to clamp(18px,2.4vw,30px)", "usage": "12-column card grids" }
    },
    "radius": {
      "xs": "2px", "sm": "6px", "md": "10px", "lg": "14px", "xl": "18px",
      "pill": "100px", "round": "50%"
    },
    "elevation": {
      "card": { "value": "0 34px 70px -28px rgba(37,35,35,0.35)", "usage": "Light work card hover" },
      "card-dark": { "value": "0 40px 80px -34px rgba(24,23,21,0.80)", "usage": "Showcase card hover on night" },
      "panel": { "value": "0 40px 80px -44px rgba(37,35,35,0.35)", "usage": "Browser-frame mock" },
      "terminal": { "value": "0 34px 70px -40px rgba(24,23,21,0.55)", "usage": "Console mock" },
      "focus-ring": { "value": "0 0 0 3px rgba(36,62,232,0.15)", "usage": "Focused inputs" },
      "note": "Shadows appear only on hover/elevation moments — resting UI is flat with hairline borders"
    },
    "motion": {
      "easing": {
        "css-signature": { "value": "cubic-bezier(0.22,0.75,0.25,1)", "usage": "Every CSS transition (--ease)" },
        "gsap-default": { "value": "power3.out", "duration": 1, "usage": "gsap.defaults()" },
        "gsap-headline": { "value": "power4.out", "usage": "Hero line reveals, service headlines" },
        "gsap-counter": { "value": "power2.out", "usage": "Metric counters" },
        "gsap-pop": { "value": "back.out(1.7)", "usage": "Icon/arrow entrances" }
      },
      "duration": {
        "micro": "0.2s", "hover": "0.3–0.45s", "element": "0.5–0.6s",
        "reveal": "0.8–1.15s", "counter": "1.8s", "ticker-loop": "40s", "grain-loop": "8s steps(10)"
      },
      "choreography": {
        "stagger": "0.08–0.09s",
        "reveal-rise": "36–44px translateY + fade",
        "hero-lines": "yPercent 112 → 0, 1.15s power4.out, stagger 0.09",
        "scroll-trigger-start": "top 82–90%, once: true",
        "scrub-parallax": "0.4–1.0 scrub for glow/ghost/art drift",
        "magnetic": "quickTo x/y, 0.4s power3, strength 0.28 of pointer offset"
      },
      "reduced-motion": "Every animation is disabled or reduced under prefers-reduced-motion; ticker wraps statically, timeline fill renders complete"
    },
    "texture": {
      "grain": { "value": "SVG fractalNoise, baseFrequency 0.9, opacity 0.05, 8s stepped jitter", "usage": "Fixed full-viewport film grain overlay" }
    }
  },
  "semantic": {
    "light": {
      "color-bg": "{primitive.color.porcelain}",
      "color-bg-raised": "{primitive.color.bone}",
      "color-bg-card": "{primitive.color.bone}",
      "color-text": "{primitive.color.ink}",
      "color-text-secondary": "{primitive.color.alpha.ink-62}",
      "color-text-tertiary": "{primitive.color.alpha.ink-40}",
      "color-border": "{primitive.color.alpha.ink-13}",
      "color-accent": "{primitive.color.cobalt}",
      "color-accent-strong": "{primitive.color.cobalt}",
      "color-accent-soft": "{primitive.color.cobalt}",
      "color-on-accent": "{primitive.color.bone}",
      "color-success": "{primitive.color.green}",
      "color-error": "{primitive.color.red-text}",
      "color-selection-bg": "{primitive.color.cobalt}",
      "color-selection-text": "{primitive.color.porcelain}"
    },
    "on-night": {
      "color-bg": "{primitive.color.night}",
      "color-bg-raised": "{primitive.color.night}",
      "color-bg-card": "{primitive.color.night}",
      "color-text": "{primitive.color.bone}",
      "color-text-secondary": "{primitive.color.alpha.paper-55}",
      "color-border": "{primitive.color.alpha.paper-16}",
      "color-accent": "{primitive.color.cobalt}",
      "color-accent-soft": "{primitive.color.cobalt}"
    }
  },
  "component": {
    "button": {
      "radius": "{primitive.radius.pill}",
      "padding": "17px 32px",
      "padding-compact": "12px 24px (nav)",
      "font-size": "15.5px",
      "weight": 700,
      "variants": {
        "fill": { "bg": "{semantic.color-accent}", "text": "{semantic.color-on-accent}" },
        "line": { "border": "1px solid {semantic.color-text}", "text": "{semantic.color-text}" }
      },
      "hover": "Ink veil scales up from bottom (scaleY 0→1, 0.38s signature ease); arrow icon shifts +4px"
    },
    "eyebrow": {
      "font": "mono 12px, tracking 0.16em, uppercase",
      "color": "{semantic.color-accent}",
      "prefix": "26×2px accent dash"
    },
    "nav": {
      "height": "78px",
      "scrolled": "background rgba-scrim + 14px backdrop blur + hairline bottom border",
      "active-link": "2px cobalt underline offset -7px",
      "mobile-breakpoint": "780px"
    },
    "tag": {
      "font": "mono 10.5px, tracking 0.10em, uppercase",
      "padding": "7px 13px", "radius": "pill",
      "border": "1px solid {semantic.color-border}",
      "selected": "cobalt fill, white text (pills / filters)"
    },
    "card-work": {
      "radius": "14px", "bg": "bone", "border": "hairline",
      "hover": "translateY -8px + card shadow; art scales 1.05 over 0.7s",
      "reveal": "clip-path inset bottom → 0 over 1.1s power3.out"
    },
    "card-showcase": {
      "radius": "18px", "bg": "night", "aspect": "16/11",
      "frame": "1px inset hairline at 14px, tightens to 10px on hover",
      "art-resting": "saturate 0.72 brightness 0.82 — blooms to full color on hover",
      "hover": "translateY -4px, dark shadow, arrow chip rotates 45° and fills cobalt"
    },
    "input": {
      "bg": "{primitive.color.porcelain}", "radius": "10px", "padding": "15px 16px",
      "focus": "cobalt border + 3px cobalt-15 ring",
      "error": "red border + 12.5px red text"
    },
    "metric": {
      "number": "display 800, clamp(40px,5.4vw,76px), accent em highlights",
      "counter": "GSAP 1.8s power2.out, en-IN locale formatting"
    },
    "ticker": { "loop": "40s linear infinite, pauses on hover", "separator": "8px cobalt dot" },
    "loader": { "bg": "night", "exit": "translateY -101% over 0.9s signature ease" },
    "cursor": { "dot": "10px white, mix-blend difference; grows to 56px over interactive targets; fine pointers only" }
  }
}
